<?xml version="1.0"?>
<robot name="racecar" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- 包含传感器宏定义 -->
  <xacro:include filename="sensors.xacro"/>

  <!-- ========== 属性参数 ========== -->
  <xacro:property name="base_mass" value="2.0" />
  <xacro:property name="base_inertia_ixx" value="0.05" />
  <xacro:property name="base_inertia_iyy" value="0.05" />
  <xacro:property name="base_inertia_izz" value="0.02" />
  <xacro:property name="chassis_length" value="0.5" />
  <xacro:property name="chassis_width" value="0.35" />
  <xacro:property name="chassis_height" value="0.08" />

  <!-- 轮子参数 -->
  <xacro:property name="wheel_radius" value="0.06" />
  <xacro:property name="wheel_length" value="0.06" />
  <xacro:property name="wheel_mass" value="0.1" />
  <xacro:property name="wheel_separation" value="0.48" />
  <xacro:property name="wheelbase" value="0.30" />

  <!-- 轮轴位置 -->
  <xacro:property name="rear_axle_x" value="-0.12" />
  <xacro:property name="front_axle_x" value="0.18" />

  <!-- ========== 底盘 link ========== -->
  <link name="base_link">
    <inertial>
      <mass value="${base_mass}" />
      <inertia ixx="${base_inertia_ixx}" ixy="0" ixz="0"
               iyy="${base_inertia_iyy}" iyz="0"
               izz="${base_inertia_izz}" />
    </inertial>
    <visual>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}" />
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1" />
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}" />
      </geometry>
    </collision>
  </link>

  <!-- ========== 车轮宏（绕 Z 轴旋转，符合 AckermannSteering 插件规范）========== -->
  <xacro:macro name="wheel_link" params="prefix x y">
    <link name="${prefix}_wheel_link">
      <inertial>
        <mass value="${wheel_mass}"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
      <visual>
        <geometry>
          <cylinder length="${wheel_length}" radius="${wheel_radius}"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <geometry>
          <cylinder length="${wheel_length}" radius="${wheel_radius}"/>
        </geometry>
      </collision>
    </link>
  </xacro:macro>

  <!-- 后轮（驱动轮） -->
  <xacro:wheel_link prefix="left_rear" x="${rear_axle_x}" y="${wheel_separation/2}"/>
  <xacro:wheel_link prefix="right_rear" x="${rear_axle_x}" y="${-wheel_separation/2}"/>

  <!-- 后轮关节（绕 Z 轴旋转） -->
  <joint name="left_rear_wheel_joint" type="continuous">
    <origin xyz="${rear_axle_x} ${wheel_separation/2} -0.02" rpy="-1.5708 0 0"/>
    <parent link="base_link"/>
    <child link="left_rear_wheel_link"/>
    <axis xyz="0 0 1"/>
  </joint>
  <joint name="right_rear_wheel_joint" type="continuous">
    <origin xyz="${rear_axle_x} ${-wheel_separation/2} -0.02" rpy="-1.5708 0 0"/>
    <parent link="base_link"/>
    <child link="right_rear_wheel_link"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- 前轮转向节 -->
  <xacro:wheel_link prefix="left_front" x="${front_axle_x}" y="${wheel_separation/2}"/>
  <xacro:wheel_link prefix="right_front" x="${front_axle_x}" y="${-wheel_separation/2}"/>

  <!-- 左前转向节 link -->
  <link name="left_front_steer_link">
    <inertial>
      <mass value="0.05" />
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001" />
    </inertial>
    <visual>
      <geometry><box size="0.02 0.02 0.04" /></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1" /></material>
    </visual>
    <collision>
      <geometry><box size="0.02 0.02 0.04" /></geometry>
    </collision>
  </link>
  <joint name="left_front_steer_joint" type="revolute">
    <parent link="base_link"/>
    <child link="left_front_steer_link"/>
    <origin xyz="${front_axle_x} ${wheel_separation/2} 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.6" upper="0.6" effort="0.5" velocity="1.0"/>
  </joint>

  <!-- 左前轮（安装在转向节上） -->
  <joint name="left_front_wheel_joint" type="continuous">
    <parent link="left_front_steer_link"/>
    <child link="left_front_wheel_link"/>
    <origin xyz="0 0 -0.02" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- 右前转向节 link -->
  <link name="right_front_steer_link">
    <inertial>
      <mass value="0.05" />
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001" />
    </inertial>
    <visual>
      <geometry><box size="0.02 0.02 0.04" /></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1" /></material>
    </visual>
    <collision>
      <geometry><box size="0.02 0.02 0.04" /></geometry>
    </collision>
  </link>
  <joint name="right_front_steer_joint" type="revolute">
    <parent link="base_link"/>
    <child link="right_front_steer_link"/>
    <origin xyz="${front_axle_x} ${-wheel_separation/2} 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.6" upper="0.6" effort="0.5" velocity="1.0"/>
  </joint>

  <!-- 右前轮（安装在转向节上） -->
  <joint name="right_front_wheel_joint" type="continuous">
    <parent link="right_front_steer_link"/>
    <child link="right_front_wheel_link"/>
    <origin xyz="0 0 -0.02" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ========== 传感器 ========== -->
  <xacro:velodyne_vlp16 parent="base_link">
    <origin xyz="0 0 0.12" rpy="0 0 0" />
  </xacro:velodyne_vlp16>
  <xacro:usb_camera parent="base_link">
    <origin xyz="0.23 0 0.09" rpy="0 0 0" />
  </xacro:usb_camera>
  <xacro:imu_sensor parent="base_link">
    <origin xyz="0 0 0.02" rpy="0 0 0" />
  </xacro:imu_sensor>
  <xacro:gps_sensor parent="base_link">
    <origin xyz="-0.18 0 0.04" rpy="0 0 0" />
  </xacro:gps_sensor>
  <xacro:magnetometer parent="base_link">
    <origin xyz="0.15 0.1 0.02" rpy="0 0 0" />
  </xacro:magnetometer>

  <!-- ========== Gazebo 阿克曼转向插件 ========== -->
  <gazebo>
    <plugin filename="gz-sim-ackermann-steering-system" name="gz::sim::systems::AckermannSteering">
      <left_joint>left_rear_wheel_joint</left_joint>
      <right_joint>right_rear_wheel_joint</right_joint>
      <left_steering_joint>left_front_steer_joint</left_steering_joint>
      <right_steering_joint>right_front_steer_joint</right_steering_joint>
      <wheel_base>${wheelbase}</wheel_base>
      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <steering_limit>0.6</steering_limit>
      <max_velocity>3.0</max_velocity>
      <min_velocity>-3.0</min_velocity>
    </plugin>
  </gazebo>

  <!--==========Gazebo 关节状态发布插件 =========-->
  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
          name="gz::sim::systems::JointStatePublisher">
    </plugin>
  </gazebo>

</robot>