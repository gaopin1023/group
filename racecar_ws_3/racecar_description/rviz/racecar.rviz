          Show Trail: false
          Value: true
        left_front_wheel_link:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        left_rear_wheel_link:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        magnetometer_link:
          Alpha: 1
          Show Axes: false
          Show Trail: false
